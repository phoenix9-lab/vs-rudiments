		"path": "/client/animations/-",
		"value": {
			"code": "rudimentscarding",
			"animation": "rudimentscarding",
			"blendMode": "Add",
			"elementWeight": {
				"UpperArmR": 100,
				"LowerArmR": 100,
				"UpperArmL": 100,
